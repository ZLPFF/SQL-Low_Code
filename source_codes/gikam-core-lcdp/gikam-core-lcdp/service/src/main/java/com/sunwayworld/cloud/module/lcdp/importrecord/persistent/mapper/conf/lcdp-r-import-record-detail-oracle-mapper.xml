<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sunwayworld.cloud.module.lcdp.importrecord.persistent.mapper.LcdpRImportRecordDetailMapper">
    <select id="selectByCondition" parameterType="map" resultType="map">
        SELECT T.* FROM (
        SELECT DD.*,RD.CREATEDTIME RECORDTIME
        FROM T_LCDP_R_IMPORT_RECORD_DETAIL DD
        LEFT  JOIN T_LCDP_RESOURCE_IMPORT_RECORD RD
        on DD.recordid = rd.id
        ) T

        <where>
            <include refid="com.sunwayworld.framework.mybatis.mapper.GlobalMapper.appendWhereClausesIfPresent" />
        </where>
        ORDER BY
        <choose>
            <when test="orderParams != null and orderParams.size > 0">
                <include refid="com.sunwayworld.framework.mybatis.mapper.GlobalMapper.appendOrderClause" />
            </when>
            <otherwise>
                T.ID DESC
            </otherwise>
        </choose>
    </select>

</mapper>