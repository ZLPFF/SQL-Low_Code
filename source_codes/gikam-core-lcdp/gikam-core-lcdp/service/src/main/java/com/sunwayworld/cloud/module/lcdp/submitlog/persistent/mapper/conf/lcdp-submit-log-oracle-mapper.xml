<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sunwayworld.cloud.module.lcdp.submitlog.persistent.mapper.LcdpSubmitLogMapper">
    <select id="selectByCondition" parameterType="map" resultType="map">
        SELECT T.*
          FROM T_LCDP_SUBMIT_LOG T
        <where>
            <if test="resourceName != null">
                EXISTS (SELECT 1
                          FROM T_LCDP_RESOURCE_VERSION V
                         WHERE V.LOGID = T.ID
                           AND UPPER(V.RESOURCENAME) LIKE ('%' || #{resourceName} || '%'))
            </if>
            <include refid="com.sunwayworld.framework.mybatis.mapper.GlobalMapper.appendWhereClausesIfPresent" />
        </where>
        ORDER BY
        <choose>
            <when test="orderParams != null and orderParams.size > 0">
                <include refid="com.sunwayworld.framework.mybatis.mapper.GlobalMapper.appendOrderClause" />
            </when>
            <otherwise>
                T.ID DESC
            </otherwise>
        </choose>
    </select>

</mapper>